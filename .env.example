# Copy to .env.local and paste your keys after the equals signs (for: vercel dev)
# Production: add each name in Vercel → Project → Settings → Environment Variables

GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Supabase — get these from Supabase → Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
